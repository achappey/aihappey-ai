data: {"type":"response.shell_call_command.done","command":"python - <<'PY'\nfrom artifact_tool import SpreadsheetArtifact\n\nwb = SpreadsheetArtifact('Fakton_Simpele_Spreadsheet')\nsh = wb.create_sheet('Overzicht')\n\nsh.cell('A1').value = 'Simpele voorbeeldspreadsheet'\nsh.cell('A3').value = 'Maand'\nsh.cell('B3').value = 'Omzet (€)'\nsh.cell('C3').value = 'Kosten (€)'\nsh.cell('D3').value = 'Winst (€)'\nsh.cell('E3').value = 'Winstmarge'\n\ndata = [\n    ('Jan', 12000, 7500),\n    ('Feb', 15000, 8200),\n    ('Mrt', 13000, 7900),\n]\nstart_row = 4\nfor idx,(m,omzet,kosten) in enumerate(data):\n    r = start_row+idx\n    sh.cell(f'A{r}').value = m\n    sh.cell(f'B{r}').value = omzet\n    sh.cell(f'C{r}').value = kosten\n    sh.cell(f'D{r}').formula = f'=B{r}-C{r}'\n    sh.cell(f'E{r}').formula = f'=IF(B{r}=0,\"\",D{r}/B{r})'\n\n# totals\nsh.cell('A7').value = 'Totaal'\nsh.cell('B7').formula = '=SUM(B4:B6)'\nsh.cell('C7').formula = '=SUM(C4:C6)'\nsh.cell('D7').formula = '=B7-C7'\nsh.cell('E7').formula = '=IF(B7=0,\"\",D7/B7)'\n\nwb.recalculate()\nwb.render()\n\nout_path='/mnt/data/simpele_spreadsheet.xlsx'\nwb.export(out_path, overwrite=True)\nprint(out_path)\nPY","command_index":0,"output_index":22,"sequence_number":2540}

