ed = wb.render()\n# export to /mnt/data with explicit filename\nimport os\nout_path = '/mnt/data/simpele_spreadsheet.xlsx'\nwb.export(out_path, overwrite=True)\nprint('rendered', rendered)\nprint('exported', out_path, os.path.exists(out_path))\nPY"],"max_output_length":null,"timeout_ms":null},"call_id":"call_tVXbXNS3FDN8CWDqV4i3ksGB","environment":{"type":"container_reference","container_id":"cntr_69e4d95eda688191a02227d05823802709d9d41f5a8c8c90"}},"output_index":7,"sequence_number":1011}

