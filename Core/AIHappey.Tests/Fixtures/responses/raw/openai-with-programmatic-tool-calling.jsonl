rest and repayment at the time of sales, as well as retained unit sales. I understand that “verzin zelf dingen” suggests I have some freedom here, so I can create an example. I’ll run the Python code to ensure a proper calculation. The model will involve monthly debt drawn from 65% of eligible costs, and I'll need to keep everything straightforward. Let’s get coding!"}]},{"id":"cm_0e0419afad465b4b016a621d59d4e4819f94d501ddb1ae30ca","type":"program","call_id":"call_Zy8WRkveXbCo2E1laTwi1BGy","code":"const r = await tools.python.exec(`\nimport numpy as np, math, json\n\n# Zelfbedacht vastgoedontwikkelingsmodel: 100 appartementen, 10 jaar, maandbasis\nmonths = 120\ncf_project = np.zeros(months + 1)   # vóór financiering\ncf_equity = np.zeros(months + 1)    # ná financiering\n\n# Aannames\nunits = 100\nsold_units = 85\nrental_units = units - sold_units\nsale_price = 320_000\nland = 8_000_000\nconstruction = 22_000_000\nsoft_costs = 3_600_000\nmarketing = 1_000_000\ncontingency = 0.07 * (land + construction + soft_costs + marketing)\nannual_inflation = 0.025\nannual_rent_growth = 0.025\nmonthly_interest = 0.065 / 12\ndebt_ratio = 0.65\nexit_yield = 0.045\nmonthly_rent_per_unit = 1_450\noperating_cost_ratio = 0.28\ndiscount_rate_annual = 0.08\n\n# Kosten: grond bij start; bouw/soft costs verdeeld over maand 1-24\ncf_project[0] -= land\nfor m in range(1, 25):\n    inflation = (1 + annual_inflation) ** (m / 12)\n    cf_project[m] -= (construction + soft_costs) / 24 * inflation\ncf_project[18] -= marketing\ncf_project[24] -= contingency * (1 + annual_inflation) ** 2\n\n# Verkoop van 85 appartementen in maanden 30-35\nfor m in range(30, 36):\n    units_this_month = sold_units / 6\n    price = sale_price * (1 + annual_inflation) ** (m / 12)\n    cf_project[m] += units_this_month * price\n\n# Verhuur van 15 appartementen vanaf maand 30, met eindwaarde op maand 120\nfor m in range(30, 121):\n    years_from_start = m / 12\n    gross_rent = rental_units * monthly_rent_per_unit * (1 + annual_rent_growth) ** years_from_start\n    cf_project[m] += gross_rent * (1 - operating_cost_ratio)\nif True:\n    annual_noi_exit = rental_units * monthly_rent_per_unit * 12 * (1 + annual_rent_growth) ** 10 * (1 - operating_cost_ratio)\n    cf_project[120] += annual_noi_exit / exit_yield\n\n# Financiering: 65% van positieve ontwikkelingskosten wordt opgenomen\ndebt_balance = 0.0\nfor m in range(months + 1):\n    eligible_costs = max(0, -cf_project[m])\n    draw = debt_ratio * eligible_costs\n    interest = debt_balance * monthly_interest\n    principal_repayment = 0.0\n\n    # Schuld wordt volledig afgelost uit de kasstroom op einddatum\n    if m == months:\n        principal_repayment = debt_balance + draw\n\n    cf_equity[m] = cf_project[m] + draw - interest - principal_repayment\n    debt_balance += draw - principal_repayment\n\ndef npv(rate_annual, cashflows):\n    r = (1 + rate_annual) ** (1/12) - 1\n    return sum(cf / ((1+r)**m) for m, cf in enumerate(cashflows))\n\ndef irr_monthly(cashflows, low=-0.99, high=2.0):\n    def f(r):\n        return sum(cf / ((1+r)**m) for m, cf in enumerate(cashflows))\n    # Zoek een interval met tekenwisseling\n    xs = np.linspace(-0.99, 2.0, 5000)\n    vals = [f(x) for x in xs]\n    for a, b, fa, fb in zip(xs[:-1], xs[1:], vals[:-1], vals[1:]):\n        if fa * fb < 0:\n            for _ in range(100):\n                mid = (a+b)/2\n                fm = f(mid)\n                if fa * fm <= 0:\n                    b, fb = mid, fm\n                else:\n                    a, fa = mid, fm\n            return (1 + (a+b)/2)**12 - 1\n    return None\n\ntotal_project_cost = -sum(x for x in cf_project if x < 0)\ntotal_sales = sum(x for x in cf_project if x > 0)\npeak_debt = 0.0\nbalance = 0.0\nfor m in range(months + 1):\n    costs = max(0, -cf_project[m])\n    draw = debt_ratio * costs\n    balance += draw\n    balance -= balance * 0  # alleen voor leesbaarheid; rente wordt niet gekapitaliseerd\n    if m == months:\n        balance = 0\n    peak_debt = max(peak_debt, balance)\n\nresult = {\n    \"totale_ontwikkelingskosten\": round(total_project_cost),\n    \"totale_inkomsten_incl_eindwaarde\": round(total_sales),\n    \"project_NPV_bij_8pct\": round(npv(discount_rate_annual, cf_project)),\n    \"equity_NPV_bij_8pct\": round(npv(discount_rate_annual, cf_equity)),\n    \"equity_IRR\": round(irr_monthly(cf_equity) * 100, 2),\n    \"maximale_schuld_excl_rente\": round(peak_debt),\n    \"eigen_vermogen_inleg\": round(-sum(x for x in cf_equity if x < 0)),\n    \"eindwaarde_verhuur\": round(annual_noi_exit / exit_yield),\n    \"netto_winst_project\": round(sum(cf_project)),\n    \"netto_winst_equity\": round(sum(cf_equity)),\n}\nprint(json.dumps(result, indent=2))\n`);\nfor (const item of r) if (item.type === \"logs\") text(item.logs);\n","fingerprint":"gAAAAABqYh17CtN7xsVJ8Ys6aQsbOo79TD4KeSU3MKi9GjX4wScqQBlOrdW8ENItgZjG7Bi0z0vcvVazfXuNhY2ov6AqHBOeK8OeiB2dtrauP24vzsBrCPx5H1iy41aWmVpAIJs6vVVXyrvPiDf01Zys54ro6dBH0yRpyJX2geTwKSESbKJFz68Vf3dSCPenZ1DDoe5jfRlKPOFkViTppp1gi4bokz_fJ0p4bVKMJsAOprr3BMK_2g6SzMhd5v4aWfNGwl6vhClEiJQXK4nPFTBELZFyFpF-Uz4X2I3JlimIDMvcaJMr_i-5-sZYGLtaea6p9VI2W2ElVH131acu3XFSC54iEprxL1h-KepL9cEUJAAfhXcbbCmjHziaOGV3C5zGOSazM9k3eVjqXlWOv3AD3bWw-23X0ZxQTgadXBc0bLOWmjuaLCBtiksnFDIIHakM9itfqFNq92lug5ll46UuWqMmRYyzE3OmOYJPMT7S5ihl1BGbYKz8bdp35-rdiCH-Ukf-BgYFRFeQG1q8Q2_ZeKr5po0WtbkOuiEzBIyoEX0fsVvvTaVfe-m8PbDroH0c7N46xM2tHTa9v8jOPKAT98cDNAEAepRshx20juvrQTKYq41JK-WCasBp6t-OsEAIJPRFwyuIbfOcKdIJc3ttTpgVU3N5SRLcC1ADgG1yJYosImCQ4TyL5cP8PaZWe4F9_LSsipinNefJPKmgxmR_KjZ9VOSLbCg2tzN4qyDC4dd8qO7C8AVStv59rkZG_XurmBqdItOGxKXYkBPY_Aah7aktxvOkaTofez-b0Pg1M0RhIlQVbKGWDR8kz75aWMizJVA80JRJ0vBQQJx0vCJoXm_aLIrkRUCxDwb_qQV3i_ExavP7b6-0j6PJr1x1LLSvfDX9rRROnoSIBJ-pvtg7yEE9HvufdrRuZREcCB6r6CrB2aAObebAUaDr135JV_SxjbMbzx7SrSLka8jBoATU17FaadS-S5qYScsUQQUThtel6fn_zGdIELzDaofB4uAP1eqbz8xAvvL4-Mv67MJE7R3TJwCIw4Qi0Jq-0_uaPJ0I70UauQap1W0PUy396exvdM3pxd8pWDrpDapGpdA8xTPAq-vc9P4vsyMKgmrW-jADsQjuC9AEaAUj5L4w6KxpoQ