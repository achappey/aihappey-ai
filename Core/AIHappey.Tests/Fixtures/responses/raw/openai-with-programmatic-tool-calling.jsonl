eeld over 24 maanden\nfor maand in range(1, 25):\n    inflatiefactor = (1 + inflatie) ** (maand / 12)\n\n    maandelijkse_kosten = (\n        (bouwkosten + advieskosten) / 24\n    ) * inflatiefactor\n\n    cashflow_project[maand] -= maandelijkse_kosten\n\n# Marketingkosten in maand 18\ncashflow_project[18] -= marketingkosten\n\n# Risicoreserve in maand 24\ncashflow_project[24] -= (\n    contingency * (1 + inflatie) ** 2\n)\n\n# -----------------------------\n# Verkoopopbrengsten\n# -----------------------------\n# Verkoop vindt plaats in zes maanden\nfor maand in range(30, 36):\n    inflatiefactor = (1 + inflatie) ** (maand / 12)\n\n    opbrengst_per_maand = (\n        verkochte_appartementen / 6\n    ) * verkoopprijs * inflatiefactor\n\n    cashflow_project[maand] += opbrengst_per_maand\n\n# -----------------------------\n# Huuropbrengsten\n# -----------------------------\nfor maand in range(30, 121):\n    huurinkomsten = (\n        verhuurde_appartementen\n        * huur_per_maand\n        * (1 + huurgroei) ** (maand / 12)\n    )\n\n    netto_huurinkomsten = (\n        huurinkomsten * (1 - exploitatiekosten)\n    )\n\n    cashflow_project[maand] += netto_huurinkomsten\n\n# -----------------------------\n# Eindwaarde verhuurportefeuille\n# -----------------------------\nnetto_noi_in_jaar_10 = (\n    verhuurde_appartementen\n    * huur_per_maand\n    * 12\n    * (1 + huurgroei) ** 10\n    * (1 - exploitatiekosten)\n)\n\neindwaarde = netto_noi_in_jaar_10 / exit_yield\ncashflow_project[120] += eindwaarde\n\n# -----------------------------\n# Schuld en rente\n# -----------------------------\nschuld = 0\nmaximale_schuld = 0\n\nfor maand in range(maanden + 1):\n    negatieve_cashflow = max(0, -cashflow_project[maand])\n\n    opname = schuldpercentage * negatieve_cashflow\n    rente = schuld * maandrente\n\n    # Schuld wordt aan het einde volledig afgelost\n    aflossing = 0\n\n    if maand == maanden:\n        aflossing = schuld + opname\n\n    cashflow_equity[maand] = (\n        cashflow_project[maand]\n        + opname\n        - rente\n        - aflossing\n    )\n\n    schuld += opname - aflossing\n    maximale_schuld = max(maximale_schuld, schuld)\n\n# -----------------------------\n# NPV-berekening\n# -----------------------------\ndef bereken_npv(jaarrente, cashflows):\n    maandrente = (1 + jaarrente) ** (1 / 12) - 1\n\n    return sum(\n        cashflow / ((1 + maandrente) ** maand)\n        for maand, cashflow in enumerate(cashflows)\n    )\n\n# -----------------------------\n# IRR-berekening met bisection\n# -----------------------------\ndef bereken_irr(cashflows):\n    def npv_bij_rente(rente):\n        return sum(\n            cashflow / ((1 + rente) ** maand)\n            for maand, cashflow in enumerate(cashflows)\n        )\n\n    laag = -0.99\n    hoog = 0.50\n\n    for _ in range(200):\n        midden = (laag + hoog) / 2\n\n        if npv_bij_rente(laag) * npv_bij_rente(midden) <= 0:\n            hoog = midden\n        else:\n            laag = midden\n\n    maandelijkse_irr = (laag + hoog) / 2\n\n    return (1 + maandelijkse_irr) ** 12 - 1\n\n# -----------------------------\n# Resultaten\n# -----------------------------\ntotale_kosten = -sum(\n    cashflow for cashflow in cashflow_project\n    if cashflow < 0\n)\n\ntotale_opbrengsten = sum(\n    cashflow for cashflow in cashflow_project\n    if cashflow > 0\n)\n\nproject_npv = bereken_npv(\n    discontovoet,\n    cashflow_project\n)\n\nequity_npv = bereken_npv(\n    discontovoet,\n    cashflow_equity\n)\n\nequity_irr = bereken_irr(cashflow_equity)\n\nprint(\"RESULTATEN\")\nprint(\"-\" * 40)\nprint(f\"Totale kosten:              €{totale_kosten:,.0f}\")\nprint(f\"Totale opbrengsten:         €{totale_opbrengsten:,.0f}\")\nprint(f\"Project-NPV bij 8%:         €{project_npv:,.0f}\")\nprint(f\"Equity-NPV bij 8%:          €{equity_npv:,.0f}\")\nprint(f\"Equity-IRR:                 {equity_irr:.2%}\")\nprint(f\"Maximale schuld:            €{maximale_schuld:,.0f}\")\nprint(f\"Eindwaarde verhuur:         €{eindwaarde:,.0f}\")\n```\n\nDit is natuurlijk een **illustratief model**. In een echt model zou je nog zaken toevoegen zoals btw, vennootschapsbelasting, verkoopkosten, leegstand, bouwvertraging, rente op rente, verschillende financieringstranches en Monte Carlo-risicoanalyse."},"sequence_number":2217}

