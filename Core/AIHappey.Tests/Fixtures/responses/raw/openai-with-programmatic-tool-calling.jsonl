data: {"type":"response.output_item.done","item":{"id":"cm_0e0419afad465b4b016a621d65ec14819fbeddad81a09e32e0","type":"program","call_id":"call_ohdbXJ9W6qcy9vKLseOkBW4s","code":"const r = await tools.python.exec(`\nimport numpy as np, json\n\nmonths=120\ncf_project=np.zeros(months+1)\ncf_equity=np.zeros(months+1)\n\nunits=100; sold_units=85; rental_units=15\nsale_price=400_000\nland=7_000_000; construction=20_000_000; soft_costs=3_200_000; marketing=900_000\ncontingency=0.06*(land+construction+soft_costs+marketing)\ninflation=0.025; rent_growth=0.025; rent=1500; opex=0.28\ndebt_ratio=0.65; monthly_interest=0.065/12\nexit_yield=0.04\n\ncf_project[0]-=land\nfor m in range(1,25):\n    cf_project[m]-=(construction+soft_costs)/24*(1+inflation)**(m/12)\ncf_project[18]-=marketing\ncf_project[24]-=contingency*(1+inflation)**2\n\nfor m in range(30,36):\n    cf_project[m]+=(sold_units/6)*sale_price*(1+inflation)**(m/12)\n\nfor m in range(30,121):\n    noi=rental_units*rent*(1+rent_growth)**(m/12)*(1-opex)\n    cf_project[m]+=noi\nannual_noi_exit=rental_units*rent*12*(1+rent_growth)**10*(1-opex)\ncf_project[120]+=annual_noi_exit/exit_yield\n\n# Schuld: opnemen op kosten, maandrente cash betaald, eindaflossing\ndebt=0\npeak=0\nfor m in range(121):\n    draw=debt_ratio*max(0,-cf_project[m])\n    interest=debt*monthly_interest\n    repay=debt+draw if m==120 else 0\n    cf_equity[m]=cf_project[m]+draw-interest-repay\n    debt += draw-repay\n    peak=max(peak,debt)\n\ndef npv(rate, cfs):\n    rm=(1+rate)**(1/12)-1\n    return sum(float(c)/((1+rm)**m) for m,c in enumerate(cfs))\n\ndef irr(cfs):\n    def f(r): return npv(r,cfs)\n    grid=np.linspace(-0.99,0.5,3000)\n    vals=[f(x) for x in grid]\n    for a,b,fa,fb in zip(grid[:-1],grid[1:],vals[:-1],vals[1:]):\n        if fa*fb<0:\n            for _ in range(80):\n                mid=(a+b)/2\n                if f(a)*f(mid)<=0: b=mid\n                else: a=mid\n            return (1+(a+b)/2)**12-1\n    return None\n\nprint(json.dumps({\n\"totale kosten\": round(-sum(x for x in cf_project if x<0)),\n\"totale opbrengsten\": round(sum(x for x in cf_project if x>0)),\n\"project NPV 8%\": round(npv(.08,cf_project)),\n\"equity NPV 8%\": round(npv(.08,cf_equity)),\n\"equity IRR\": round(irr(cf_equity)*100,2),\n\"max schuld\": round(peak),\n\"eigen vermogen\": round(-sum(x for x in cf_equity if x<0)),\n\"eindwaarde verhuur\": round(annual_noi_exit/exit_yield),\n\"netto projectresultaat\": round(sum(cf_project)),\n\"netto equityresultaat\": round(sum(cf_equity))\n}, indent=2))\n`);\nfor (const item of r) if (item.type === \"logs\") text(item.logs);\n","fingerprint":"gAAAAABqYh1ll30wWmJk1WNCjpB_G75bdNguBJzF5bqovhRwuBGrxDKxHp2IvxNkaHGnCd7SlmmEGhqUjC_ZnQ5UwCvKpWEvIjgAuVgUOPQacdCxw2D9vnWlURGQAeAhxjZyogOrtvdMeoQEuUZKbgrsvTvyRS-8OhuNWxG_1sn9BqX9z4lFjFPrCaeqhzmy29LmUI1w0tEVol86CH1y6w8xtmukv1G76rsu-A4shKq-Dt-tC8TxOjPl4pZuU53U7r3PDqNESzVtsauaJhG2vZmKVoxdwt_5ObHRUFkSGwbsH1cFovCXh57lS3KcWdhZwNkhqxRfCsySpXaQDKIi_Wit2C67DG9rjH5u-ahe6tk2Es67k6OVDGU11EEfiYH-gLfSP16CEiWVKzcEq88fOQudO91L_CmTPg7pk2TIvyekzBfdo5vIGgE6tv6O06fXUeZPAspt6p39rmLFitnK2IYkZWkeqw-SF3N4PcpGsYJbtMzDNUbYELWX4QQi6-h0Ohrtu7LTjTYW9WwuDAAcNL1Nnl3O_uj1EEsqe27aA9zbezzD497xfqjdxNmPXdcWR_Yu0D7nM3q1WCsir8ypviToeq4z8D30IQtUG_VgNvWeMm9N3IGRVu_YRRaMBA-ubZ0Jd7rI4OJJckw1qzX4fl40_idTbUtOaoKwlNRZgBt8LJdeiouuTWZCVdCnTSMncnh-_UmLw-WpUX-rwsWCu1WXnC_NqMiVVtq1jOT5ruhFQBQqvgPsOkYHTIc4cps1V1RVzjFpfL6SUro8LdO1e5I6F4-OEJy4HFBElymPPOf8q_GUr-dHAA8HUHuHLlwV7CpoU06dJZutwoLfclzopl0RdcLUVnzo2StsGd1DXayomV_cjWnka6F0Da51nReJdDDzSygxWpnFk7DW3j9kw_it22b4_pgmXGQN9EFd_vGti9hIC6iKlJxS5-n5vNt5YnNRzYhix7IdNAcOtHsiHwRALxYy_giJgg0krPeOEUZ8YHxs4wrmxZTZSWkIVeZy9QEDwLS0rcd6JB6tBrTsWn7LgDpbVwNxjNHhF4pxINizeln6yq32fBpd9ASGOMAinoNthWLuMuRs8Y4Jg2dWfUcMw2013pjPdC1_Jd3Xp2vukHJH2Y1lAffxXBGo-fp9uFAkPgLH6odTdxOuJSQ1-HGJVycdNmf2ouiF5FRFQKriaEee7vtx6fYU9p7vtLX4-ZVtejM8p1qcHOdLlIP99F3dbm_3IeyG8kET8Ng2CwGJ0APJ0pt3WkkRGzFJ6XUUm2Af_cCTrkkoj_gPzfRHuNAkkrRgz5wtwyF7EH54BB-6uRJihBCVYHPq5WQMGjrLvgpN3Nolw08uPPWwv9