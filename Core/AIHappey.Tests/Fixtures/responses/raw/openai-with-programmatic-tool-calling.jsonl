data: {"type":"response.code_interpreter_call_code.done","code":"\nimport numpy as np, json\n\nmonths=120\ncf_project=np.zeros(months+1)\ncf_equity=np.zeros(months+1)\n\nunits=100; sold_units=85; rental_units=15\nsale_price=400_000\nland=7_000_000; construction=20_000_000; soft_costs=3_200_000; marketing=900_000\ncontingency=0.06*(land+construction+soft_costs+marketing)\ninflation=0.025; rent_growth=0.025; rent=1500; opex=0.28\ndebt_ratio=0.65; monthly_interest=0.065/12\nexit_yield=0.04\n\ncf_project[0]-=land\nfor m in range(1,25):\n    cf_project[m]-=(construction+soft_costs)/24*(1+inflation)**(m/12)\ncf_project[18]-=marketing\ncf_project[24]-=contingency*(1+inflation)**2\n\nfor m in range(30,36):\n    cf_project[m]+=(sold_units/6)*sale_price*(1+inflation)**(m/12)\n\nfor m in range(30,121):\n    noi=rental_units*rent*(1+rent_growth)**(m/12)*(1-opex)\n    cf_project[m]+=noi\nannual_noi_exit=rental_units*rent*12*(1+rent_growth)**10*(1-opex)\ncf_project[120]+=annual_noi_exit/exit_yield\n\n# Schuld: opnemen op kosten, maandrente cash betaald, eindaflossing\ndebt=0\npeak=0\nfor m in range(121):\n    draw=debt_ratio*max(0,-cf_project[m])\n    interest=debt*monthly_interest\n    repay=debt+draw if m==120 else 0\n    cf_equity[m]=cf_project[m]+draw-interest-repay\n    debt += draw-repay\n    peak=max(peak,debt)\n\ndef npv(rate, cfs):\n    rm=(1+rate)**(1/12)-1\n    return sum(float(c)/((1+rm)**m) for m,c in enumerate(cfs))\n\ndef irr(cfs):\n    def f(r): return npv(r,cfs)\n    grid=np.linspace(-0.99,0.5,3000)\n    vals=[f(x) for x in grid]\n    for a,b,fa,fb in zip(grid[:-1],grid[1:],vals[:-1],vals[1:]):\n        if fa*fb<0:\n            for _ in range(80):\n                mid=(a+b)/2\n                if f(a)*f(mid)<=0: b=mid\n                else: a=mid\n            return (1+(a+b)/2)**12-1\n    return None\n\nprint(json.dumps({\n\"totale kosten\": round(-sum(x for x in cf_project if x<0)),\n\"totale opbrengsten\": round(sum(x for x in cf_project if x>0)),\n\"project NPV 8%\": round(npv(.08,cf_project)),\n\"equity NPV 8%\": round(npv(.08,cf_equity)),\n\"equity IRR\": round(irr(cf_equity)*100,2),\n\"max schuld\": round(peak),\n\"eigen vermogen\": round(-sum(x for x in cf_equity if x<0)),\n\"eindwaarde verhuur\": round(annual_noi_exit/exit_yield),\n\"netto projectresultaat\": round(sum(cf_project)),\n\"netto equityresultaat\": round(sum(cf_equity))\n}, indent=2))\n","item_id":"ci_0e0419afad465b4b016a621d660728819f835a1a31d35de29d","output_index":10,"sequence_number":330}

